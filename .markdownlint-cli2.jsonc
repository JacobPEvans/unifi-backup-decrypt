{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 160,
      "heading_line_length": 120,
      "code_block_line_length": 160,
      "tables": false
    },
    "MD024": {
      "siblings_only": true
    },
    "MD060": false
  },
  "fix": true,
  "gitignore": true,
  "ignores": [
    ".github/aw/**",
    "CHANGELOG.md"
  ]
}
